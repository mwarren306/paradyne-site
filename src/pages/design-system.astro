---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Paradyn Design System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <script src="https://mcp.figma.com/mcp/html-to-design/capture.js" async></script>
    <script>
      if (window.location.hash.includes('figmacapture')) {
        const style = document.createElement('style');
        style.textContent = '* { opacity: 1 !important; transform: none !important; transition: none !important; animation: none !important; }';
        document.head.appendChild(style);
      }
    </script>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: #050508;
        color: #fff;
        font-family: 'Inter', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .ds-page { padding: 0; }
      .ds-section {
        padding: 80px 60px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        position: relative;
      }
      .ds-section-header {
        margin-bottom: 48px;
      }
      .ds-eyebrow {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #3ecfbe;
        margin-bottom: 10px;
      }
      .ds-title {
        font-size: 32px;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: #fff;
        margin-bottom: 8px;
      }
      .ds-subtitle {
        font-size: 14px;
        color: rgba(255,255,255,0.4);
        line-height: 1.6;
      }
      .ds-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.35);
        margin-top: 10px;
      }
      .ds-value {
        font-size: 11px;
        font-weight: 500;
        color: rgba(255,255,255,0.5);
        margin-top: 3px;
        font-family: 'SF Mono', 'Fira Code', monospace;
      }
      .ds-grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
      .ds-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
      .ds-grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
      .ds-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(55,194,215,0.2), transparent);
        margin: 0;
      }
    </style>
  </head>
  <body class="ds-page">

    <!-- ─── COVER ─────────────────────────────────────────── -->
    <section id="ds-cover" style="
      background: #050508;
      padding: 100px 60px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      position: relative;
      overflow: hidden;
    ">
      <div style="
        position: absolute; inset: 0; pointer-events: none;
        background:
          radial-gradient(ellipse 70% 60% at 80% 50%, rgba(55,194,215,0.10) 0%, transparent 65%),
          radial-gradient(ellipse 40% 40% at 20% 60%, rgba(89,191,142,0.07) 0%, transparent 55%);
      "></div>
      <div style="position: relative; max-width: 700px;">
        <div style="display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; border-radius: 999px; background: rgba(55,194,215,0.09); border: 1px solid rgba(55,194,215,0.3); color: #7dd8e8; font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 28px;">
          Design System v1.0
        </div>
        <h1 style="font-size: 72px; font-weight: 800; letter-spacing: -0.04em; line-height: 1.0; margin-bottom: 20px;">
          Paradyn<br/>
          <span style="background: linear-gradient(135deg, #37c2d7, #59bf8e); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Design System</span>
        </h1>
        <p style="font-size: 16px; color: rgba(255,255,255,0.45); line-height: 1.7; max-width: 480px;">
          A complete reference of design tokens, color variables, typography scales, and UI components for the Paradyn web platform.
        </p>
        <div style="display: flex; gap: 32px; margin-top: 40px;">
          {['Color Tokens', 'Typography', 'Components', 'Patterns'].map(s => (
            <div style="font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.3); letter-spacing: 0.06em;">{s}</div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── COLOR TOKENS ──────────────────────────────────── -->
    <section id="ds-colors" class="ds-section" style="background: #06090a;">
      <div class="ds-section-header">
        <div class="ds-eyebrow">01 — Foundation</div>
        <h2 class="ds-title">Color Tokens</h2>
        <p class="ds-subtitle">All color values defined as CSS custom properties in <code style="background:rgba(255,255,255,0.07);padding:2px 6px;border-radius:4px;font-size:12px;">@theme {}</code> in global.css. Use tokens, never raw hex values.</p>
      </div>

      <!-- Backgrounds -->
      <div style="margin-bottom: 40px;">
        <div style="font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.5); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px;">Backgrounds</div>
        <div class="ds-grid-4">
          {[
            { name: '--color-bg', hex: '#050508', label: 'Page Background', usage: 'Main page bg, hero, sections' },
            { name: '--color-surface', hex: '#06090a', label: 'Surface', usage: 'Alternate section bg (Research, Contact, Impact)' },
            { name: '--color-card', hex: 'rgba(255,255,255,0.03)', label: 'Card', usage: '.card base background' },
            { name: '--color-card-hi', hex: 'rgba(255,255,255,0.045)', label: 'Card Elevated', usage: '.card-hi background' },
          ].map(c => (
            <div>
              <div style={`height: 80px; border-radius: 12px; background: ${c.hex}; border: 1px solid rgba(255,255,255,0.12);`}></div>
              <div class="ds-label">{c.label}</div>
              <div class="ds-value">{c.name}</div>
              <div class="ds-value" style="color: rgba(255,255,255,0.3);">{c.hex}</div>
              <div style="font-size: 10px; color: rgba(255,255,255,0.22); margin-top: 4px; line-height: 1.4;">{c.usage}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Brand -->
      <div style="margin-bottom: 40px;">
        <div style="font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.5); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px;">Brand</div>
        <div class="ds-grid-4">
          {[
            { name: '--color-primary', hex: '#37c2d7', label: 'Primary Teal', usage: 'Icon borders, active states, glows, gradient start' },
            { name: '--color-secondary', hex: '#59bf8e', label: 'Secondary Green', usage: 'Gradient end, founder avatar' },
            { name: 'accent-teal', hex: '#3ecfbe', label: 'Accent Teal', usage: 'Section labels, role text (.section-label)' },
            { name: 'badge-text', hex: '#7dd8e8', label: 'Badge Text', usage: 'Pill badge text color, icon stroke' },
          ].map(c => (
            <div>
              <div style={`height: 80px; border-radius: 12px; background: ${c.hex};`}></div>
              <div class="ds-label">{c.label}</div>
              <div class="ds-value">{c.name}</div>
              <div class="ds-value" style="color: rgba(255,255,255,0.3);">{c.hex}</div>
              <div style="font-size: 10px; color: rgba(255,255,255,0.22); margin-top: 4px; line-height: 1.4;">{c.usage}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Brand Gradient -->
      <div style="margin-bottom: 40px;">
        <div style="font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.5); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px;">Brand Gradient</div>
        <div class="ds-grid-2">
          <div>
            <div style="height: 80px; border-radius: 12px; background: linear-gradient(135deg, #37c2d7, #59bf8e);"></div>
            <div class="ds-label">Brand Gradient — 135°</div>
            <div class="ds-value">linear-gradient(135deg, #37c2d7, #59bf8e)</div>
            <div style="font-size: 10px; color: rgba(255,255,255,0.22); margin-top: 4px;">Used on: Nav CTA, Contact CTA button, .g-text, icon-box bg, founder avatars</div>
          </div>
          <div>
            <div style="height: 80px; border-radius: 12px; background: linear-gradient(135deg, rgba(55,194,215,0.2), rgba(89,191,142,0.2)); border: 1px solid rgba(55,194,215,0.2);"></div>
            <div class="ds-label">Brand Gradient — 20% Opacity</div>
            <div class="ds-value">linear-gradient(135deg, rgba(55,194,215,0.2), rgba(89,191,142,0.2))</div>
            <div style="font-size: 10px; color: rgba(255,255,255,0.22); margin-top: 4px;">Used on: .icon-box background</div>
          </div>
        </div>
      </div>

      <!-- Text -->
      <div style="margin-bottom: 40px;">
        <div style="font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.5); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px;">Text</div>
        <div class="ds-grid-4">
          {[
            { name: '--color-text', hex: '#ffffff', label: 'Text Primary', usage: 'Headings, card titles, names' },
            { name: 'text-muted-45', hex: 'rgba(255,255,255,0.45)', label: 'Text Muted 45%', usage: 'Body copy, card body, paragraphs' },
            { name: 'text-muted-25', hex: 'rgba(255,255,255,0.25)', label: 'Text Muted 25%', usage: 'Secondary muted text' },
            { name: 'text-muted-22', hex: 'rgba(255,255,255,0.22)', label: 'Text Muted 22%', usage: 'Captions, footer, tertiary labels' },
          ].map(c => (
            <div>
              <div style={`height: 80px; border-radius: 12px; background: ${c.hex}; border: 1px solid rgba(255,255,255,0.1);`}></div>
              <div class="ds-label">{c.label}</div>
              <div class="ds-value">{c.name}</div>
              <div class="ds-value" style="color: rgba(255,255,255,0.3);">{c.hex}</div>
              <div style="font-size: 10px; color: rgba(255,255,255,0.22); margin-top: 4px; line-height: 1.4;">{c.usage}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Borders -->
      <div>
        <div style="font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.5); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px;">Borders & Muted</div>
        <div class="ds-grid-4">
          {[
            { name: '--color-border', hex: 'rgba(255,255,255,0.07)', label: 'Border Default', usage: '.card border, nav border-bottom' },
            { name: '--color-border-hi', hex: 'rgba(255,255,255,0.12)', label: 'Border Elevated', usage: '.card-hi border, active step borders' },
            { name: '--color-muted', hex: '#7a8a88', label: 'Muted', usage: 'De-emphasized text' },
            { name: '--color-muted-hi', hex: '#a0b8b4', label: 'Muted High', usage: 'Slightly brighter muted text' },
          ].map(c => (
            <div>
              <div style={`height: 80px; border-radius: 12px; background: ${c.hex}; border: 1px solid rgba(255,255,255,0.1);`}></div>
              <div class="ds-label">{c.label}</div>
              <div class="ds-value">{c.name}</div>
              <div class="ds-value" style="color: rgba(255,255,255,0.3);">{c.hex}</div>
              <div style="font-size: 10px; color: rgba(255,255,255,0.22); margin-top: 4px; line-height: 1.4;">{c.usage}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="ds-divider"></div>

    <!-- ─── TYPOGRAPHY ─────────────────────────────────────── -->
    <section id="ds-typography" class="ds-section" style="background: #050508;">
      <div class="ds-section-header">
        <div class="ds-eyebrow">02 — Foundation</div>
        <h2 class="ds-title">Typography</h2>
        <p class="ds-subtitle">Font family: <strong>Inter</strong> (Google Fonts). Weights loaded: 300, 400, 500, 600, 700, 800. All sizes use px or clamp() — no rem.</p>
      </div>

      <div style="display: flex; flex-direction: column; gap: 0;">
        {[
          {
            name: 'Hero Headline',
            token: 'type/hero-headline',
            sample: 'Applied AI Infrastructure',
            style: 'font-size: clamp(42px, 7vw, 80px); font-weight: 800; letter-spacing: -0.03em; line-height: 1.1; color: #fff;',
            spec: 'clamp(42px, 7vw, 80px) · weight 800 · tracking -0.03em · lh 1.1',
            usage: 'Hero section H1',
          },
          {
            name: 'Section Headline',
            token: 'type/section-headline',
            sample: 'Small businesses are drowning',
            style: 'font-size: clamp(30px, 4vw, 48px); font-weight: 800; letter-spacing: -0.02em; line-height: 1.15; color: #fff;',
            spec: 'clamp(30px, 4vw, 48px) · weight 800 · tracking -0.02em · lh 1.15',
            usage: 'All section H2 headings',
          },
          {
            name: 'Contact Headline',
            token: 'type/contact-headline',
            sample: "Let's Build Something Together",
            style: 'font-size: clamp(32px, 5vw, 60px); font-weight: 800; letter-spacing: -0.03em; line-height: 1.1; color: #fff;',
            spec: 'clamp(32px, 5vw, 60px) · weight 800 · tracking -0.03em · lh 1.1',
            usage: 'Contact section H2',
          },
          {
            name: 'Card Title',
            token: 'type/card-title',
            sample: 'Disconnected Tools',
            style: 'font-size: 16px; font-weight: 700; color: #fff; line-height: 1.4;',
            spec: '16px · weight 700 · color #fff',
            usage: 'Card headings, step labels',
          },
          {
            name: 'Body',
            token: 'type/body',
            sample: 'Many SMBs operate across fragmented tools, resulting in duplicated effort and inconsistent data.',
            style: 'font-size: 16px; font-weight: 400; color: rgba(255,255,255,0.45); line-height: 1.7;',
            spec: '16px · weight 400 · color rgba(255,255,255,0.45) · lh 1.7',
            usage: 'Section supporting paragraphs',
          },
          {
            name: 'Card Body',
            token: 'type/card-body',
            sample: 'Spreadsheets, email, accounting, POS, and CRM operating in silos — creating duplicated effort.',
            style: 'font-size: 14px; font-weight: 400; color: rgba(255,255,255,0.45); line-height: 1.7;',
            spec: '14px · weight 400 · color rgba(255,255,255,0.45) · lh 1.7',
            usage: 'Card body text',
          },
          {
            name: 'Section Label',
            token: 'type/section-label',
            sample: 'The Problem',
            style: 'font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #3ecfbe;',
            spec: '11px · weight 600 · tracking 0.12em · UPPERCASE · color #3ecfbe',
            usage: '.section-label — appears above every H2',
          },
          {
            name: 'Pill Badge',
            token: 'type/pill-badge',
            sample: 'NSF-aligned Research',
            style: 'font-size: 12px; font-weight: 500; letter-spacing: 0.03em; color: #7dd8e8;',
            spec: '12px · weight 500 · tracking 0.03em · color #7dd8e8',
            usage: '.pill-badge text, step tags',
          },
          {
            name: 'Nav Link',
            token: 'type/nav-link',
            sample: 'Research · Approach · Founders · Contact',
            style: 'font-size: 14px; font-weight: 400; color: rgba(255,255,255,0.5);',
            spec: '14px · weight 400 · color rgba(255,255,255,0.5) → #fff on hover',
            usage: 'Navigation link items',
          },
          {
            name: 'Button Primary',
            token: 'type/button-primary',
            sample: 'Get in Touch',
            style: 'font-size: 16px; font-weight: 700; color: #050508;',
            spec: '16px · weight 700 · color #050508 (dark on light bg)',
            usage: 'Primary CTA button (gradient bg)',
          },
          {
            name: 'Button Secondary',
            token: 'type/button-secondary',
            sample: 'Meet the Team',
            style: 'font-size: 15px; font-weight: 600; color: rgba(255,255,255,0.7);',
            spec: '15px · weight 600 · color rgba(255,255,255,0.7)',
            usage: 'Ghost/outline button',
          },
          {
            name: 'Caption / Footer',
            token: 'type/caption',
            sample: '© 2026 Paradyn, LLC · All rights reserved · Tupelo, MS',
            style: 'font-size: 12px; font-weight: 400; color: rgba(255,255,255,0.22);',
            spec: '12px · weight 400 · color rgba(255,255,255,0.22)',
            usage: 'Footer text, tertiary labels, trusted-by tags',
          },
        ].map(t => (
          <div style="padding: 28px 0; border-bottom: 1px solid rgba(255,255,255,0.05); display: grid; grid-template-columns: 160px 1fr 220px; gap: 32px; align-items: center;">
            <div>
              <div style="font-size: 12px; font-weight: 700; color: #fff; margin-bottom: 4px;">{t.name}</div>
              <div style="font-size: 10px; font-weight: 500; font-family: monospace; color: rgba(55,194,215,0.7); margin-bottom: 6px;">{t.token}</div>
              <div style="font-size: 10px; color: rgba(255,255,255,0.22); line-height: 1.5;">{t.usage}</div>
            </div>
            <div style={t.style}>{t.sample}</div>
            <div style="font-size: 10px; font-family: monospace; color: rgba(255,255,255,0.35); line-height: 1.7;">{t.spec}</div>
          </div>
        ))}
      </div>
    </section>

    <div class="ds-divider"></div>

    <!-- ─── SPACING & RADIUS ───────────────────────────────── -->
    <section id="ds-spacing" class="ds-section" style="background: #06090a;">
      <div class="ds-section-header">
        <div class="ds-eyebrow">03 — Foundation</div>
        <h2 class="ds-title">Spacing & Radius</h2>
        <p class="ds-subtitle">Core layout constants used throughout the site. All spacing is in px.</p>
      </div>

      <div style="margin-bottom: 48px;">
        <div style="font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.5); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 20px;">Spacing Scale</div>
        <div style="display: flex; flex-direction: column; gap: 12px;">
          {[
            { token: 'spacing/section-v', value: '120px', usage: 'Section vertical padding (top & bottom)' },
            { token: 'spacing/section-h', value: '24px', usage: 'Section horizontal padding (sides)' },
            { token: 'spacing/section-v-lg', value: '140px', usage: 'Contact section vertical padding' },
            { token: 'spacing/content-max', value: '1100px', usage: 'Max-width for inner section content' },
            { token: 'spacing/nav-max', value: '1200px', usage: 'Max-width for navigation' },
            { token: 'spacing/nav-h', value: '64px', usage: 'Navigation bar height' },
            { token: 'spacing/card-pad', value: '28px', usage: '.card padding' },
            { token: 'spacing/card-hi-pad', value: '36px', usage: '.card-hi padding (founder cards)' },
            { token: 'spacing/section-gap', value: '64px', usage: 'Heading to content gap within sections' },
            { token: 'spacing/icon-box', value: '44px', usage: '.icon-box size (width & height)' },
          ].map(s => (
            <div style="display: grid; grid-template-columns: 200px 80px 1fr; gap: 16px; align-items: center; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.04);">
              <div style="font-size: 11px; font-family: monospace; color: rgba(55,194,215,0.7);">{s.token}</div>
              <div style="font-size: 13px; font-weight: 700; color: #fff;">{s.value}</div>
              <div style="font-size: 12px; color: rgba(255,255,255,0.35);">{s.usage}</div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <div style="font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.5); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 20px;">Border Radius</div>
        <div style="display: flex; gap: 24px; align-items: flex-end;">
          {[
            { token: 'radius/sm', value: '12px', usage: 'icon-box, step buttons' },
            { token: 'radius/card', value: '16px', usage: '.card, .card-hi' },
            { token: 'radius/avatar', value: '18px', usage: 'Founder avatar' },
            { token: 'radius/full', value: '999px', usage: 'Buttons, pill badges, nav CTA' },
          ].map(r => (
            <div style="flex: 1;">
              <div style={`width: 100%; height: 60px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: ${r.value};`}></div>
              <div class="ds-label">{r.token}</div>
              <div class="ds-value">{r.value}</div>
              <div style="font-size: 10px; color: rgba(255,255,255,0.22); margin-top: 3px;">{r.usage}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="ds-divider"></div>

    <!-- ─── BUTTONS ────────────────────────────────────────── -->
    <section id="ds-buttons" class="ds-section" style="background: #050508;">
      <div class="ds-section-header">
        <div class="ds-eyebrow">04 — Components</div>
        <h2 class="ds-title">Buttons</h2>
        <p class="ds-subtitle">Three button variants. All use <code style="background:rgba(255,255,255,0.07);padding:2px 6px;border-radius:4px;font-size:12px;">border-radius: 999px</code>. Primary and secondary use Framer Motion <code style="background:rgba(255,255,255,0.07);padding:2px 6px;border-radius:4px;font-size:12px;">whileHover / whileTap</code>.</p>
      </div>

      <div style="display: flex; flex-direction: column; gap: 48px;">

        <!-- Primary -->
        <div>
          <div style="font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.5); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 20px;">Primary — Gradient Fill</div>
          <div style="display: flex; gap: 24px; align-items: center; flex-wrap: wrap;">
            <a style="display: inline-flex; align-items: center; gap: 12px; padding: 16px 32px; border-radius: 999px; background: linear-gradient(135deg, #37c2d7, #59bf8e); color: #050508; font-size: 16px; font-weight: 700; text-decoration: none; box-shadow: 0 0 28px rgba(55,194,215,0.30);">
              <span style="width: 32px; height: 32px; border-radius: 50%; background: rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
              Get in Touch
            </a>
            <div style="font-size: 12px; font-family: monospace; color: rgba(255,255,255,0.35); line-height: 1.8;">
