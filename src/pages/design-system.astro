            { name: 'Nav CTA Glow', token: 'motion/nav-cta-hover', spec: 'whileHover: scale 1.05, boxShadow 0 0 24px rgba(55,194,215,0.45)', usage: 'Navigation CTA button' },
            { name: 'Step Button Slide', token: 'motion/step-hover', spec: 'whileHover: x 4, duration 0.18s', usage: 'Approach step selector buttons' },
            { name: 'Avatar Scale', token: 'motion/avatar-hover', spec: 'whileHover: scale 1.06, duration 0.2s', usage: 'Founder avatar initials' },
            { name: 'Scroll Cue Bounce', token: 'motion/scroll-cue', spec: 'animate: y [0,7,0], repeat Infinity, 1.5s easeInOut', usage: 'Hero scroll indicator line' },
          ].map(a => (
            <div style="padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.04);">
              <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px;">
                <span style="font-size: 12px; font-weight: 600; color: #fff;">{a.name}</span>
                <span style="font-size: 10px; font-family: monospace; color: rgba(55,194,215,0.7);">{a.token}</span>
              </div>
              <div style="font-size: 10px; font-family: monospace; color: rgba(255,255,255,0.35); margin-bottom: 3px;">{a.spec}</div>
              <div style="font-size: 10px; color: rgba(255,255,255,0.22);">{a.usage}</div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <div class="ds-divider"></div>

